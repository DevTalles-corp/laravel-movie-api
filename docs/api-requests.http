@baseUrl = http://movie-api.test/api
@genreId = 3

@movieId = 1

GET {{baseUrl}}/health
Accept: application/json

### Listar todos los géneros
GET {{baseUrl}}/genres
Accept: application/json

### Crear un género
POST {{baseUrl}}/genres
Content-Type: application/json
Accept: application/json

{
  "name": "Suspenso",
  "description": "Películas con tensión y giros inesperados.",
  "is_active": true
}

### Ver un género
GET {{baseUrl}}/genres/{{genreId}}
Accept: application/json

### Actualizar un género
PUT {{baseUrl}}/genres/{{genreId}}
Content-Type: application/json
Accept: application/json

{
  "name": "Suspenso Psicológico",
  "is_active": true
}

### Eliminar un género (soft delete)
DELETE {{baseUrl}}/genres/{{genreId}}
Accept: application/json

### Listar géneros con filtros y ordenamiento
GET {{baseUrl}}/genres?search=en&is_active=true&sort_by=name&order=desc
Accept: application/json

### Buscar género por slug
GET {{baseUrl}}/genres/slug/suspenso-psicologico
Accept: application/json

### Restaurar un género eliminado
POST {{baseUrl}}/genres/{{genreId}}/restore
Accept: application/json

### =============================
### PELÍCULAS
### =============================

### Listar todas las películas
GET {{baseUrl}}/movies
Accept: application/json

### Listar películas con filtros
GET {{baseUrl}}/movies?search=padrino&year=1972&min_rating=8&genre_id=4&sort_by=rating&order=desc
Accept: application/json

### Crear una película
POST {{baseUrl}}/movies
Content-Type: application/json
Accept: application/json

{
  "title": "Blade Runner",
  "synopsis": "Un policía caza androides en un futuro distópico.",
  "year": 1982,
  "rating": 8.1,
  "director": "Ridley Scott",
  "duration": 117,
  "genre_ids": [6]
}

### Ver una película
GET {{baseUrl}}/movies/{{movieId}}
Accept: application/json

### Actualizar una película
PUT {{baseUrl}}/movies/{{movieId}}
Content-Type: application/json
Accept: application/json

{
  "rating": 9.0,
  "genre_ids": [4]
}

### Eliminar una película (soft delete)
DELETE {{baseUrl}}/movies/{{movieId}}
Accept: application/json
